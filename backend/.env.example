# =============================================================
# BarrierLakeOps — backend (FastAPI + MCP) 環境變數範本
# 使用方式: cp .env.example .env 後填入實際值
# 本檔僅供 backend/ 使用,與 frontend/.env 各自獨立
# =============================================================

# ---- 對外服務 ----
PORT=8000                      # Zeabur 會注入 $PORT,本機預設 8000
ENVIRONMENT=development        # development | production
LOG_LEVEL=INFO
# 允許跨來源的前端網域(逗號分隔)。本機 + Zeabur 前端網域
CORS_ORIGINS=http://localhost:3000

# ---- 中央氣象署 Opendata API (Tool 2 上游雨量) ----
# 申請: https://opendata.cwa.gov.tw/user/authkey
CWA_API_KEY=
CWA_MEMBER_TIER=general

# ---- LLM (Tool 5 compose_briefing + Chat Agent) ----
# 本專案使用 OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# ---- (延伸選項) NCDR Datahub Token ----
# 申請: https://datahub.ncdr.nat.gov.tw/
NCDR_TOKEN=

# ---- 資料庫 (Postgres：持久化 briefings 稽核 + chat 歷史) ----
# 本機(docker-compose 起的 Postgres):
DATABASE_URL=postgresql://barrierlake:barrierlake@localhost:5432/barrierlake
# Zeabur 上由 Postgres service 注入(template 部署後自動帶入連線字串)

# ---- 本地資料與快取 ----
CACHE_DIR=./.cache
# 內建地理資料(前處理後 DEM .npy / 村里界 GeoJSON)路徑
DATA_DIR=./data

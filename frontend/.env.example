# =============================================================
# BarrierLakeOps — frontend (Nuxt 3) 環境變數範本
# 使用方式: cp .env.example .env 後填入實際值
# 本檔僅供 frontend/ 使用,與 backend/.env 各自獨立
# =============================================================

# 後端 REST API base URL(server 端與 client 端共用)
# 本機: http://localhost:8000 ; Zeabur: https://<backend>.zeabur.app
NUXT_PUBLIC_API_BASE=http://localhost:8000

# 地圖底圖 tile(Leaflet / OpenStreetMap)
NUXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NUXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors

# Nuxt/Nitro 對外埠(Zeabur 會注入 $PORT)
PORT=3000

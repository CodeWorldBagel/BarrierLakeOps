# =============================================================
# BarrierLakeOps MCP Server - 環境變數範本
# =============================================================
# 使用方式:
#   1. 複製本檔為 .env: cp .env.example .env
#   2. 填入各 API Key 的實際值
#   3. .env 已由 .gitignore 排除,不會被 commit
# =============================================================

# 中央氣象署 Opendata API
# 申請: https://opendata.cwa.gov.tw/user/authkey
CWA_API_KEY=
CWA_MEMBER_TIER=general

# LLM (二選一,Tool 5 compose_briefing 用)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# (延伸選項) NCDR Datahub Token
# 申請: https://datahub.ncdr.nat.gov.tw/
NCDR_TOKEN=

# 開發模式
LOG_LEVEL=INFO
CACHE_DIR=./.cache
ENVIRONMENT=development

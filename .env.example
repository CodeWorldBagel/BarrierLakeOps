# ── 本機 docker compose 環境變數範本 ──
# 複製成 .env 後「務必填入」下列兩個密碼(留空則 docker compose up 會被 :? 檢查擋下):
#   cp .env.example .env  然後編輯 .env 填 POSTGRES_PASSWORD / MINIO_ROOT_PASSWORD
# .env 已被 .gitignore 忽略,不會進版控;正式環境(Zeabur)請用 service 變數,勿用此檔。
# 此範本刻意不含任何密碼字面值(避免弱掃誤判為 hardcoded password)。
POSTGRES_USER=barrierlake
POSTGRES_PASSWORD=
POSTGRES_DB=barrierlake
MINIO_ROOT_USER=barrierlake
MINIO_ROOT_PASSWORD=
